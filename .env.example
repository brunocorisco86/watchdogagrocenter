# CONFIGURAÇÕES DO SERVIÇO DE MONITORAMENTO
AGROCENTER_URL=https://prd-agrocenter.cvale.com.br
CHECK_INTERVAL_MINUTES=5
REQUEST_TIMEOUT_SECONDS=10
MAX_CONSECUTIVE_FAILURES_BEFORE_EMAIL=3

# TELEGRAM BOT (aiogram)
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# SMTP CONFIGURATION (Para envio de e-mails)
SMTP_SERVER=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu_usuario@exemplo.com
SMTP_PASSWORD=sua_senha_aqui
SMTP_FROM=watchdog@cvale.com.br

# DATABASE
SQLITE_DB_PATH=src/watchdog/database.db

# CONFIGURAÇÕES DO DASHBOARD FLASK
FLASK_APP=src/dashboard/app.py
FLASK_ENV=development
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
